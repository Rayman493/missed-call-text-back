# Capacitor Mobile Preview Environment Variables
# Copy this file to .env.capacitor and configure for your preview environment

# The URL that the mobile app will load in the WebView
# For internal preview, point to your development/staging instance
# For production mobile, point to the production instance
CAPACITOR_SERVER_URL=https://www.replyflowhq.com

# Alternative: Use local development server
# CAPACITOR_SERVER_URL=http://localhost:3000

# Alternative: Use staging environment
# CAPACITOR_SERVER_URL=https://staging.replyflowhq.com
