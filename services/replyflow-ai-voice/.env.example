# OpenAI API Key
OPENAI_API_KEY=sk-...

# Internal API Secret (must match Vercel INTERNAL_API_SECRET)
# Used for server-to-server authentication to /api/ai-confirmation-sms
INTERNAL_API_SECRET=your-secret-here

# Main App URL (Vercel deployment URL)
MAIN_APP_URL=https://replyflowhq.com

# Port (default: 8080)
PORT=8080
