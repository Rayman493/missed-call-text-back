{
  "name": "replyflow-ai-voice",
  "version": "1.0.0",
  "description": "AI Voice Service for ReplyFlowHQ - Phase 1A POC",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --outDir dist --target ES2020 --module commonjs --skipLibCheck --noEmitOnError false",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "twilio",
    "openai",
    "websocket",
    "voice",
    "ai"
  ],
  "author": "ReplyFlowHQ",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.4.5",
    "openai": "^4.20.0",
    "twilio": "^4.19.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
