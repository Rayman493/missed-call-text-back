# Android Release Signing Configuration
# Copy this file to keystore.properties and fill in your actual values
# keystore.properties is ignored by Git - never commit real credentials

# Path to the keystore file (relative to android/ directory)
storeFile=replyflow-release-test.keystore

# Keystore password
storePassword=YOUR_STORE_PASSWORD

# Key alias
keyAlias=replyflow-release

# Key password
keyPassword=YOUR_KEY_PASSWORD
